    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "JWT Authorization header using the Bearer Scheme\r\n\r\n.Enter 'Bearer [space] and then your token in the text input below \r\n\r\nExample:Bearer 12345abcdef \r\nName:Authorization \r\nIn:header",
        "name": "Authorization",
        "in": "header"
      }
