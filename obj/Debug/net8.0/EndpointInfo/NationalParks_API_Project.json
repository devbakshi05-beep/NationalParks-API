  "components": {
    "schemas": {
      "DifficultyType": {
        "enum": [
          0,
          1,
          2
        ],
        "type": "integer",
        "format": "int32"
      },
      "NationalPark": {
        "required": [
          "name",
          "state"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "state": {
            "minLength": 1,
            "type": "string"
          },
          "picture": {
            "type": "string",
            "format": "byte",
            "nullable": true
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "established": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "NationalParkDto": {
        "required": [
          "name",
          "state"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "state": {
            "minLength": 1,
            "type": "string"
          },
          "picture": {
            "type": "string",
            "format": "byte",
            "nullable": true
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "established": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "TrailDto": {
        "required": [
          "distance",
          "elevation",
          "name"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "distance": {
            "minLength": 1,
            "type": "string"
          },
          "elevation": {
            "minLength": 1,
            "type": "string"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time"
          },
          "difficulty": {
            "$ref": "#/components/schemas/DifficultyType"
          },
          "nationalParkId": {
            "type": "integer",
            "format": "int32"
          },
          "nationalPark": {
            "$ref": "#/components/schemas/NationalPark"
          }
        },
        "additionalProperties": false
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "userName": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "role": {
            "type": "string",
            "nullable": true
          },
          "token": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
